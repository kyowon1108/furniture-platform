# ===========================================
# Database Configuration
# ===========================================
# For SQLite (development without Docker):
# DATABASE_URL=sqlite:///./dev.db

# For PostgreSQL (Docker local):
DATABASE_URL=postgresql://furniture:furniture123@localhost:5433/furniture_db

# For PostgreSQL (Production - AWS RDS):
# DATABASE_URL=postgresql://user:password@rds-endpoint.region.rds.amazonaws.com:5432/furniture_db

# ===========================================
# Authentication
# ===========================================
SECRET_KEY=your-secret-key-change-this-in-production-must-be-at-least-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===========================================
# Server Configuration
# ===========================================
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3008,http://127.0.0.1:3008
HOST=0.0.0.0
PORT=8008

# ===========================================
# AWS S3 Settings
# ===========================================
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=furniture-platform-eunryong

# ===========================================
# PostgreSQL Docker Settings (for docker-compose)
# ===========================================
POSTGRES_USER=furniture
POSTGRES_PASSWORD=furniture123
POSTGRES_DB=furniture_db
POSTGRES_PORT=5433

# Optional: pgAdmin (run with: docker compose --profile tools up)
PGADMIN_EMAIL=admin@furniture.local
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050
